import cv2
import numpy as np
import os

def process_biscuits(image_path, biscuit_shape='circular'):
    img = cv2.imread(image_path)
    if img is None:
        print(f"Error: Could not read image at {image_path}")
        return None
    
    output = img.copy()
    
    # Grayscale Conversion
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    
    # applying Gaussian Blur
    blurred = cv2.GaussianBlur(gray, (15, 15), 0)
    
    # Thresholding
    _, thresh = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    
    # Remove small Crumbs
    kernel = np.ones((9, 9), np.uint8)
    opening = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel, iterations=2)
    
    # Fill gaps 
    closing = cv2.morphologyEx(opening, cv2.MORPH_CLOSE, kernel, iterations=2)
    
    contours, _ = cv2.findContours(closing, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    
    for cnt in contours:
        area = cv2.contourArea(cnt)
        
        # Ignore anything smaller 
        if area < 40000: 
            continue
            
        perimeter = cv2.arcLength(cnt, True)
        if perimeter == 0: continue
        
        is_intact = False
        
        # Geometric Classification
        if biscuit_shape == 'circular':
            circularity = (4 * np.pi * area) / (perimeter ** 2)
            if circularity > 0.80: 
                is_intact = True
        else:
            hull = cv2.convexHull(cnt)
            hull_area = cv2.contourArea(hull)
            solidity = float(area) / hull_area if hull_area > 0 else 0
            if solidity > 0.92: 
                is_intact = True

        # Annotation
        label = "Intact" if is_intact else "Broken"
        color = (0, 255, 0) if is_intact else (0, 0, 255) # Green for Intact, Red for Broken
        
        cv2.drawContours(output, [cnt], -1, color, 5) # Thicker contour lines
        x, y, w, h = cv2.boundingRect(cnt)
        
        cv2.putText(output, label, (x, y - 25), cv2.FONT_HERSHEY_SIMPLEX, 5, color, 5)

    return output


input_folder = r'C:\Users\amind\Desktop\Image processing\Thresholding'
output_folder = os.path.join(input_folder, 'Final_Annotated_Results')

if not os.path.exists(output_folder):
    os.makedirs(output_folder)

print("Starting process...")

for filename in os.listdir(input_folder):
    if filename.lower().endswith((".jpg", ".jpeg", ".png")):
        full_path = os.path.join(input_folder, filename)
        
        shape_type = 'square' if 'square' in filename.lower() else 'circular'
        
        print(f"Processing: {filename}...")
        result = process_biscuits(full_path, shape_type)
        
        if result is not None:
            save_path = os.path.join(output_folder, f"result_{filename}")
            cv2.imwrite(save_path, result)

print(f"\nSuccess! Images are in: {output_folder}")
